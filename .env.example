# =============================================================================
# SECURITY WARNING — NON-LOCAL / SHARED ENVIRONMENTS
# =============================================================================
# Before deploying outside localhost (staging, production, shared dev):
#   1. AUTH_PROVIDER — change from "none" to "password" or another provider
#   2. JWT_SECRET_KEY — replace "your-secret-key-here" with a strong random value
#   3. MINIO_ROOT_USER / MINIO_ROOT_PASSWORD — change from default "minioadmin"
#   4. MongoDB — enable access control (MONGO_INITDB_ROOT_USERNAME/PASSWORD)
#   5. API keys — never commit real keys; use a secrets manager in production
# Running with AUTH_PROVIDER=none disables ALL authentication checks.
# =============================================================================

# Model provider configuration
# Default: OpenRouter gateway - Get key from https://openrouter.ai/keys
# Also supports: Kimi Code, OpenAI, DeepSeek, GLM, and other OpenAI-compatible APIs
# See Multi-API Key Configuration section below for API_KEY_2, API_KEY_3
API_KEY=
API_BASE=https://openrouter.ai/api/v1

# OpenAI/OpenRouter API Keys (up to 3 keys)
# Strategy: FAILOVER (preserves prompt caching)
# Used for: Chat completions via OpenAI-compatible API
#API_KEY_2=your-backup-key-1
#API_KEY_3=your-backup-key-2

# Model configuration
# Qwen3-Coder-Next: 80B MoE (3B active), 262k context, agentic coding focus
# Pricing: $0.12/M input, $0.75/M output
MODEL_NAME=qwen/qwen3-coder-next
TEMPERATURE=0.6
MAX_TOKENS=16384
# Keep per-request timeout bounded to avoid long stalls on slow providers.
LLM_REQUEST_TIMEOUT=45
LLM_TOOL_REQUEST_TIMEOUT=45
# Adaptive Model Selection: route simple tasks to cheaper/faster models
ADAPTIVE_MODEL_SELECTION_ENABLED=true
#FAST_MODEL=claude-haiku-4-5-20251001
#BALANCED_MODEL=
#POWERFUL_MODEL=claude-sonnet-4-6

# GLM Thinking Mode Control (only applies when using Z.AI GLM-5/4.7)
# GLM models enable "deep thinking" by default, adding 10-30s latency per call.
# Set to true to disable thinking for fast agentic tool-calling responses.
# Set to false to keep thinking enabled for complex reasoning tasks.
#GLM_DISABLE_THINKING=true
# Optional: force GLM-5 full context window (docs.z.ai: 200K context length)
#LLM_CONTEXT_WINDOW_OVERRIDE=200000

# Z.AI endpoint selection for GLM-5
# General API endpoint:
#API_BASE=https://api.z.ai/api/paas/v4
# Coding Plan endpoint (coding-specific plan only):
#API_BASE=https://api.z.ai/api/coding/paas/v4

# Alternative: Kimi K2.5 Code via Kimi API
# API_BASE=https://api.kimi.com/coding/v1
# MODEL_NAME=kimi-for-coding

# Alternative: Other OpenRouter models
# MODEL_NAME=qwen/qwen3-coder
# MODEL_NAME=google/gemini-2.5-flash

# Embedding configuration (separate from chat model)
# Allows using OpenAI embeddings while using any chat provider (DeepSeek, Anthropic, etc.)
# If not set, embedding_api_key defaults to API_KEY
# See Multi-API Key Configuration section below for EMBEDDING_API_KEY_2, EMBEDDING_API_KEY_3
#EMBEDDING_API_KEY=sk-your-openai-key
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# OpenAI Embedding Keys (up to 3 keys)
# Strategy: ROUND_ROBIN (distributes high-volume load evenly)
# Use case: 10k+ embeddings/day - each key gets 1/3 of requests
# TTL Recovery: Parsed from x-ratelimit-reset-requests header
#EMBEDDING_API_KEY_2=your-backup-embedding-key-1
#EMBEDDING_API_KEY_3=your-backup-embedding-key-2

# Anthropic API Keys (up to 3 keys)
# Strategy: FAILOVER (preserves prompt caching - critical for cost savings!)
# Prompt caching reduces costs by ~90% - stick with primary key for max benefit
# TTL Recovery: Parsed from anthropic-ratelimit-tokens-reset header
#ANTHROPIC_API_KEY=your-primary-anthropic-key-here
#ANTHROPIC_API_KEY_2=your-backup-anthropic-key-1
#ANTHROPIC_API_KEY_3=your-backup-anthropic-key-2

# MongoDB configuration (access control enabled)
#MONGODB_URI=mongodb://mongodb:27017/pythinker?authSource=admin
#MONGODB_DATABASE=pythinker
#MONGODB_USERNAME=pythinker_admin
#MONGODB_PASSWORD=change-me-mongodb-password

# Redis configuration
#REDIS_HOST=redis
#REDIS_PORT=6379
#REDIS_DB=0
#REDIS_PASSWORD=
# Redis timeout settings (in seconds)
#REDIS_SOCKET_TIMEOUT=30.0
#REDIS_SOCKET_CONNECT_TIMEOUT=5.0
#REDIS_MAX_CONNECTIONS=200

# MinIO configuration (object storage for sandbox snapshots)
# WARNING: Change MINIO_ROOT_USER/PASSWORD from defaults in non-local environments
MINIO_ENDPOINT=minio:9000
#MINIO_ROOT_USER=devuser
#MINIO_ROOT_PASSWORD=devpassword
#MINIO_ACCESS_KEY=devuser
#MINIO_SECRET_KEY=devpassword
MINIO_BUCKET_SNAPSHOTS=sandbox-snapshots
MINIO_SECURE=false

# Sandbox configuration
# static: reuse pre-provisioned SANDBOX_ADDRESS hosts
# ephemeral: create/destroy sandbox container per session
SANDBOX_LIFECYCLE_MODE=static

# Sandbox streaming mode
# cdp_only: CDP screencast only (default active mode, no legacy desktop stack)
SANDBOX_STREAMING_MODE=cdp_only

# Sandbox snapshot configuration
SANDBOX_SNAPSHOT_ENABLED=false
SANDBOX_SNAPSHOT_TTL_DAYS=7
#SANDBOX_ADDRESS=
SANDBOX_IMAGE=pythinker/pythinker-sandbox
SANDBOX_NAME_PREFIX=sandbox
SANDBOX_TTL_MINUTES=30
SANDBOX_NETWORK=pythinker-network
#SANDBOX_FRAMEWORK_PORT=8082
#SANDBOX_FRAMEWORK_ENABLED=true
#SANDBOX_FRAMEWORK_REQUIRED=false
# Shared secret between backend and sandbox APIs (required in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SANDBOX_API_SECRET=change-me-to-a-random-secret
#SANDBOX_CHROME_ARGS=
#SANDBOX_HTTPS_PROXY=
#SANDBOX_HTTP_PROXY=
#SANDBOX_NO_PROXY=

# Sandbox resource limits (right-sized for single-session use)
#SANDBOX_SHM_SIZE=1g              # Shared memory for Chrome (512MB-1GB recommended)
#SANDBOX_MEM_LIMIT=3g             # Container memory limit
#SANDBOX_CPU_LIMIT=1.5            # CPU cores per container
#SANDBOX_PIDS_LIMIT=300           # Process ID limit

# Sandbox pool configuration (scale with host RAM: ~2GB per sandbox)
#SANDBOX_POOL_ENABLED=true         # Enable pre-warming pool
#SANDBOX_POOL_MIN_SIZE=2           # Pre-warmed sandboxes to maintain
#SANDBOX_POOL_MAX_SIZE=10          # Maximum sandboxes in pool (adjust to host capacity)
#MAX_CONCURRENT_AGENTS=8           # In-process agent concurrency guard
#MAX_CONCURRENT_EXECUTIONS=12      # LLM execution concurrency
#SANDBOX_POOL_WARMUP_INTERVAL=30   # Seconds between maintenance checks

# Sandbox idle management
#SANDBOX_POOL_IDLE_TTL_SECONDS=300           # Evict pooled sandbox after 5 min idle
#SANDBOX_POOL_PAUSE_IDLE=true                # Docker pause idle pooled sandboxes
#SANDBOX_POOL_HOST_MEMORY_THRESHOLD=0.80     # Stop pre-warming at 80% host RAM

# Sandbox lifecycle optimization
#SANDBOX_POOL_REAPER_INTERVAL=60             # Orphan reaper check interval (seconds)
#SANDBOX_POOL_REAPER_GRACE_PERIOD=120        # Don't reap containers younger than this

# Sandbox warmup optimization (Phase 6: race condition fix)
#SANDBOX_WARMUP_GRACE_PERIOD=3.0             # Wait before first health check (seconds)
#SANDBOX_WARMUP_INITIAL_RETRY_DELAY=1.0      # Initial delay between retries (seconds)
#SANDBOX_WARMUP_MAX_RETRY_DELAY=3.0          # Maximum delay between retries (seconds)
#SANDBOX_WARMUP_BACKOFF_MULTIPLIER=1.5       # Exponential backoff multiplier
#SANDBOX_WARMUP_CONNECTION_FAILURE_THRESHOLD=12  # Max connection failures before giving up

# Browser element extraction (Phase 6: timeout fixes)
#BROWSER_ELEMENT_EXTRACTION_TIMEOUT=7.0       # Timeout for extracting interactive elements (seconds)
#BROWSER_ELEMENT_EXTRACTION_RETRIES=2         # Number of retries for element extraction
#BROWSER_ELEMENT_EXTRACTION_RETRY_DELAY=1.0   # Delay between retries (seconds)

# Fast acknowledgment refiner (Phase 6: timeout fixes)
#FAST_ACK_REFINER_TIMEOUT=2.5                 # LLM timeout for fast ack generation (seconds)
#FAST_ACK_REFINER_TRACEBACK_SAMPLE_RATE=0.05  # Sample rate for error traceback logging (0.0-1.0)

# HuggingFace Hub token (optional but recommended)
# Set to avoid unauthenticated rate limits when downloading models (e.g. LettuceDetect hallucination detector).
# Get a free token at: https://huggingface.co/settings/tokens
#HF_TOKEN=your-huggingface-token-here

# Screenshot capture configuration (session replay + thumbnails)
SCREENSHOT_CAPTURE_ENABLED=true
SCREENSHOT_PERIODIC_INTERVAL=10.0
SCREENSHOT_QUALITY=75
SCREENSHOT_SCALE=0.5
SCREENSHOT_THUMBNAIL_QUALITY=40
SCREENSHOT_THUMBNAIL_SCALE=0.25

# Search engine configuration
# Options: duckduckgo, bing, google, brave, tavily, serper, exa, jina
SEARCH_PROVIDER=duckduckgo

# Google search configuration, only used when SEARCH_PROVIDER=google
#GOOGLE_SEARCH_API_KEY=
#GOOGLE_SEARCH_ENGINE_ID=

# =============================================================================
# Multi-API Key Configuration (Failover & Load Distribution)
# =============================================================================
# See Multi-API Key Management Configuration section below for details on strategies

# Serper.dev API Keys (up to 3 keys)
# Strategy: FAILOVER (primary → backup1 → backup2)
# Quota: 2,500 searches/month per key (free tier)
# TTL Recovery: 1 hour (quota resets hourly)
# See Multi-API Key Configuration section below for SERPER_API_KEY_2 through _9
#SERPER_API_KEY=your-primary-serper-key-here
#SERPER_API_KEY_2=your-backup-serper-key-1
#SERPER_API_KEY_3=your-backup-serper-key-2
#SERPER_API_KEY_4=your-backup-serper-key-3
#SERPER_API_KEY_5=your-backup-serper-key-4
#SERPER_API_KEY_6=your-backup-serper-key-5
#SERPER_API_KEY_7=your-backup-serper-key-6
#SERPER_API_KEY_8=your-backup-serper-key-7
#SERPER_API_KEY_9=your-backup-serper-key-8

# Tavily AI Search Keys (up to 9 keys)
# Strategy: FAILOVER (primary → backup1 → ... → backup8)
# Quota: 1,000 searches/month per key (free tier)
# TTL Recovery: 24 hours (quota resets daily)
#TAVILY_API_KEY=your-primary-tavily-key-here
#TAVILY_API_KEY_2=your-backup-tavily-key-1
#TAVILY_API_KEY_3=your-backup-tavily-key-2
#TAVILY_API_KEY_4=your-backup-tavily-key-3
#TAVILY_API_KEY_5=your-backup-tavily-key-4
#TAVILY_API_KEY_6=your-backup-tavily-key-5
#TAVILY_API_KEY_7=your-backup-tavily-key-6
#TAVILY_API_KEY_8=your-backup-tavily-key-7
#TAVILY_API_KEY_9=your-backup-tavily-key-8

# Exa API Keys (up to 5 keys)
# Strategy: FAILOVER
#EXA_API_KEY=your-primary-exa-key-here
#EXA_API_KEY_2=your-backup-exa-key-1
#EXA_API_KEY_3=your-backup-exa-key-2
#EXA_API_KEY_4=your-backup-exa-key-3
#EXA_API_KEY_5=your-backup-exa-key-4

# Jina Search/Reader API Keys (up to 5 keys)
# Strategy: FAILOVER
#JINA_API_KEY=your-primary-jina-key-here
#JINA_API_KEY_2=your-backup-jina-key-1
#JINA_API_KEY_3=your-backup-jina-key-2
#JINA_API_KEY_4=your-backup-jina-key-3
#JINA_API_KEY_5=your-backup-jina-key-4

# Optional post-search reranking via Jina
#SEARCH_USE_JINA_RERANK=false
#SEARCH_JINA_RERANK_TOP_N=8
#SEARCH_JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual

# Brave Search API Keys (up to 3 keys)
# Strategy: FAILOVER
# TTL Recovery: 24 hours
#BRAVE_SEARCH_API_KEY=your-primary-brave-key-here
#BRAVE_SEARCH_API_KEY_2=your-backup-brave-key-1
#BRAVE_SEARCH_API_KEY_3=your-backup-brave-key-2

# Auth configuration
# Options: password, none, local
AUTH_PROVIDER=password

# Password auth configuration, only used when AUTH_PROVIDER=password
PASSWORD_SALT=
PASSWORD_HASH_ROUNDS=10

# Local auth configuration, only used when AUTH_PROVIDER=local
#LOCAL_AUTH_EMAIL=admin@example.com
#LOCAL_AUTH_PASSWORD=admin

# JWT configuration
JWT_SECRET_KEY=your-secret-key-here
# Separate signing secret for refresh tokens (falls back to JWT_SECRET_KEY if unset)
# Generate with: openssl rand -base64 32
#JWT_REFRESH_SECRET_KEY=your-refresh-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=20
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email configuration
# Only used when AUTH_PROVIDER=password
#EMAIL_HOST=smtp.gmail.com
#EMAIL_PORT=587
#EMAIL_USERNAME=your-email@gmail.com
#EMAIL_PASSWORD=your-password
#EMAIL_FROM=your-email@gmail.com

# MCP configuration
#MCP_CONFIG_PATH=/etc/mcp.json

# Uvicorn workers (defaults to 4; set to CPU count for production)
#WEB_CONCURRENCY=4

# =============================================================================
# Production Scaling (docker-compose-production.yml)
# =============================================================================
# Backend replicas behind Traefik load balancer
#BACKEND_REPLICAS=4
# MongoDB WiredTiger cache size (GB) — ~50% of container memory limit
#MONGO_CACHE_SIZE_GB=1
#MONGO_MEMORY_LIMIT=2G
# Redis I/O threads (2 for < 4 CPUs, 4 for >= 8 CPUs)
#REDIS_IO_THREADS=2
#REDIS_MEMORY_LIMIT=1G
# Qdrant and MinIO memory limits
#QDRANT_MEMORY_LIMIT=2G
#MINIO_MEMORY_LIMIT=1G
#MINIO_API_REQUESTS_MAX=100
#MINIO_API_REQUESTS_DEADLINE=10s

# =============================================================================
# OpenTelemetry Distributed Tracing (optional)
# =============================================================================
# When enabled, traces all inbound HTTP requests (FastAPI) and outbound API
# calls (httpx → LLM, search, embeddings) to an OTLP-compatible collector.
# Supported backends: Jaeger, Grafana Tempo, Datadog, SigNoz, etc.
#OTEL_ENABLED=false
#OTEL_ENDPOINT=http://localhost:4317
#OTEL_SERVICE_NAME=pythinker-agent
#OTEL_INSECURE=true

# LLM-specific tracing (alternative to OTEL for LLM observability)
# Options: none, langfuse, langsmith, otel
#LLM_TRACING_PROVIDER=none
#LANGFUSE_PUBLIC_KEY=
#LANGFUSE_SECRET_KEY=
#LANGFUSE_HOST=https://cloud.langfuse.com

# Log configuration
LOG_LEVEL=INFO

# MinIO S3 Object Storage
# Self-hosted S3-compatible object storage for file uploads/downloads
# MINIO_ROOT_USER/MINIO_ROOT_PASSWORD are used by docker-compose for the MinIO server
# MINIO_ACCESS_KEY/MINIO_SECRET_KEY are used by the backend to connect as a client
# In production, use a separate service user (minio-init creates it automatically):
#   MINIO_SERVICE_USER / MINIO_SERVICE_PASSWORD -> set MINIO_ACCESS_KEY/SECRET_KEY to these
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Service user credentials (created by minio-init container)
# For dev, these default to root credentials; in production, use unique values
MINIO_SERVICE_USER=pythinker-svc
MINIO_SERVICE_PASSWORD=pythinker-svc-secret-change-me
MINIO_ACCESS_KEY=pythinker-svc
MINIO_SECRET_KEY=pythinker-svc-secret-change-me
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=pythinker
MINIO_USE_SSL=false
#MINIO_REGION=us-east-1
#MINIO_PRESIGNED_EXPIRY_SECONDS=3600
FILE_STORAGE_BACKEND=minio

# Qdrant Vector Database
# High-performance vector database for semantic memory search
QDRANT_URL=http://qdrant:6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=true
QDRANT_COLLECTION=agent_memories
#QDRANT_API_KEY=

# =============================================================================
# Agent Enhancement Configuration (Phase 1-3)
# =============================================================================

# Multi-Agent Orchestration (Phase 2)
# Enable specialized agent dispatch for individual plan steps
# When true, steps are routed to specialized agents (researcher, coder, browser, etc.)
ENABLE_MULTI_AGENT=false

# Enable full swarm coordinator mode for complex tasks
# When true, uses CoordinatorFlow with parallel agent execution
ENABLE_COORDINATOR=false

# Enable LangGraph-based PlanActFlow
# Uses LangGraph StateGraph instead of custom workflow engine
# Provides built-in checkpointing, streaming, and better composability
USE_LANGGRAPH_FLOW=false

# Agent Enhancement Feature Flags
FEATURE_FAILURE_PREDICTION=false

# Adaptive Verbosity + Clarification
# When true: logs clarification signal but skips pause.
# When false: ambiguous prompts can pause for user clarification.
FEATURE_ADAPTIVE_VERBOSITY_SHADOW=false

# Maximum number of parallel agents in swarm mode
MULTI_AGENT_MAX_PARALLEL=3

# Browser Agent Configuration
BROWSER_AGENT_ENABLED=true
BROWSER_AGENT_MAX_STEPS=25
BROWSER_AGENT_TIMEOUT=300
BROWSER_AGENT_USE_VISION=true
BROWSER_AGENT_MAX_FAILURES=5

# Browser Resource Blocking
# Control what resources are blocked for performance (ads/trackers always blocked)
BROWSER_BLOCK_RESOURCES_DEFAULT=false
# Comma-separated resource types: image, media, font, stylesheet
# Recommended: image,media (blocks heavy resources but allows CSS/fonts)
BROWSER_BLOCKED_RESOURCE_TYPES=image,media

# =============================================================================
# Timeline Replay Configuration
# =============================================================================
# Enable recording of agent actions for timeline replay
ENABLE_TIMELINE_RECORDING=true

# Number of actions between automatic state snapshots
# Lower values = faster replay reconstruction, higher storage usage
TIMELINE_SNAPSHOT_INTERVAL=50

# Days to retain detailed timeline data before cleanup
TIMELINE_RETENTION_DAYS=30

# Maximum snapshots per session (prevents unbounded growth)
TIMELINE_MAX_SNAPSHOTS_PER_SESSION=1000

# Enable compression for snapshot data
TIMELINE_COMPRESS_SNAPSHOTS=true

# =============================================================================
# Multi-API Key Management Configuration
# =============================================================================
# See: docs/architecture/MULTI_API_KEY_MANAGEMENT.md for full documentation

# Redis is REQUIRED for multi-instance key coordination
# Without Redis, keys work in single-instance in-memory mode
# Redis configuration is set above in the Redis section

# Key rotation strategies (configured automatically per provider):
# - FAILOVER: Primary → Backup (preserves caching, search engines, LLMs)
#   Used by: Serper, Tavily, Brave, OpenAI LLM, Anthropic
# - ROUND_ROBIN: Even distribution (high-volume embeddings)
#   Used by: OpenAI Embeddings
# - WEIGHTED: Quota-based distribution (future enhancement)

# TTL-based automatic recovery:
# - Serper: 1 hour (3600s) - hourly quota reset
# - Tavily: 24 hours (86400s) - daily quota reset
# - Brave: 24 hours (86400s) - monthly quota, daily TTL is safe
# - OpenAI LLM: Parsed from x-ratelimit-reset header (dynamic)
# - Anthropic: Parsed from anthropic-ratelimit-tokens-reset header (dynamic)
# - Embeddings: Parsed from x-ratelimit-reset-requests header (dynamic)

# Prometheus metrics (automatic):
# - pythinker_api_key_selections_total - Key usage counter
# - pythinker_api_key_exhaustions_total - Quota/auth failures
# - pythinker_api_key_health_score - Current health (0=unhealthy, 1=healthy)
# - pythinker_api_key_latency_seconds - Request latency per key

# Quota calculations (FREE TIER):
# Serper:
#   - Single key: 2,500 searches/month
#   - 3 keys (FAILOVER): 7,500 searches/month total
# Tavily:
#   - Single key: 1,000 searches/month
#   - 9 keys (FAILOVER): 9,000 searches/month total
# Embeddings:
#   - Single key: Rate limited by tokens/min
#   - 3 keys (ROUND_ROBIN): 3x throughput

# Migration from single-key to multi-key:
# 1. Get additional API keys from providers
# 2. Add PROVIDER_API_KEY_2, PROVIDER_API_KEY_3 to .env
# 3. Restart backend: docker-compose restart backend
# 4. Verify: docker logs pythinker-backend-1 | grep "initialized with"
#    Expected: "Serper search initialized with 3 API key(s)"

# Backward compatibility:
# - Single-key mode works exactly as before
# - Multi-key fields (_2, _3) are OPTIONAL
# - System auto-detects number of keys configured

# =============================================================================
# Autonomy Configuration
# =============================================================================
# Controls how much autonomy the agent has and which actions require user approval
# Levels: supervised (all actions need approval), guided (critical actions only),
#         autonomous (minimal approvals), unrestricted (no approvals)
AUTONOMY_LEVEL=guided

# Permission flags - these override autonomy level settings
# Set to false to completely disable a capability regardless of autonomy level
ALLOW_CREDENTIAL_ACCESS=true
ALLOW_EXTERNAL_REQUESTS=true
ALLOW_FILE_SYSTEM_WRITE=true
ALLOW_FILE_SYSTEM_DELETE=false
ALLOW_SHELL_EXECUTE=true
ALLOW_BROWSER_NAVIGATION=true  # ← Set this to false if you want to block browser usage
ALLOW_PAYMENT_OPERATIONS=false

# Safety Limits - Hard limits that apply regardless of autonomy level
MAX_ITERATIONS=400
MAX_TOOL_CALLS=500
MAX_EXECUTION_TIME_SECONDS=3600
MAX_TOKENS_PER_RUN=500000

# =============================================================================
# DSPy Prompt Optimization Pipeline
# =============================================================================
# Offline MIPROv2/GEPA optimizer that tunes planner and execution prompts.
# Results are stored as PromptProfile artifacts in MongoDB/GridFS and can be
# activated via the admin API or rolled back with one API call.
#
# Pipeline flag: set true only when you want to run optimization jobs.
# The runtime profile resolver (FEATURE_PROMPT_PROFILE_RUNTIME) is already
# enabled by default and applies saved profiles without this flag.
FEATURE_PROMPT_OPTIMIZATION_PIPELINE=false

# Runtime profile application (default: true — applies profiles when available)
# FEATURE_PROMPT_PROFILE_RUNTIME=true

# Shadow mode — compute patch deltas without applying to prompts (safe testing)
# FEATURE_PROMPT_PROFILE_SHADOW=true

# Canary rollout — % of sessions that receive the optimized profile (0=all)
# PROMPT_PROFILE_CANARY_PERCENT=0

# DSPy tuning parameters (increase threads to speed up optimization runs)
# DSPY_NUM_THREADS=4              # Parallel workers for Evaluate + MIPROv2
# DSPY_MAX_BOOTSTRAPPED_DEMOS=4   # Teacher-traced few-shot examples
# DSPY_MAX_LABELED_DEMOS=4        # Labeled trainset examples as in-context demos
# DSPY_MINIBATCH_SIZE=25          # Candidate scoring batch size (smaller=faster)
#MAX_COST_USD=10.0  # Optional cost limit in USD
