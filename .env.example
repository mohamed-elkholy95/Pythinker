# Model provider configuration
# OpenRouter API - Get your API key from https://openrouter.ai/keys
API_KEY=
API_BASE=https://openrouter.ai/api/v1

# Model configuration
# Using NVIDIA Nemotron 3 Nano 30B A3B (30B MoE, ~3B active params)
# Context: 262k tokens | Pricing: $0.06/M input, $0.24/M output
# Features: High compute efficiency, 4x token throughput vs Nemotron 2
MODEL_NAME=nvidia/nemotron-3-nano-30b-a3b
TEMPERATURE=0.7
MAX_TOKENS=8000

# Alternative: Free tier (for testing only, prompts/outputs logged)
# MODEL_NAME=nvidia/nemotron-3-nano-30b-a3b:free

# Previous model (GPT-OSS-120B - 117B parameter MoE model)
# MODEL_NAME=openai/gpt-oss-120b

# Embedding configuration (separate from chat model)
# Allows using OpenAI embeddings while using any chat provider (DeepSeek, Anthropic, etc.)
# If not set, embedding_api_key defaults to API_KEY
#EMBEDDING_API_KEY=sk-your-openai-key
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# MongoDB configuration
#MONGODB_URI=mongodb://mongodb:27017
#MONGODB_DATABASE=pythinker
#MONGODB_USERNAME=
#MONGODB_PASSWORD=

# Redis configuration
#REDIS_HOST=redis
#REDIS_PORT=6379
#REDIS_DB=0
#REDIS_PASSWORD=
# Redis timeout settings (in seconds)
#REDIS_SOCKET_TIMEOUT=30.0
#REDIS_SOCKET_CONNECT_TIMEOUT=5.0
#REDIS_MAX_CONNECTIONS=50

# Sandbox configuration
#SANDBOX_ADDRESS=
SANDBOX_IMAGE=pythinker/pythinker-sandbox
SANDBOX_NAME_PREFIX=sandbox
SANDBOX_TTL_MINUTES=30
SANDBOX_NETWORK=pythinker-network
#SANDBOX_FRAMEWORK_PORT=8082
#SANDBOX_FRAMEWORK_ENABLED=true
#SANDBOX_FRAMEWORK_REQUIRED=false
#SANDBOX_CHROME_ARGS=
#SANDBOX_HTTPS_PROXY=
#SANDBOX_HTTP_PROXY=
#SANDBOX_NO_PROXY=

# VNC Screenshot configuration (for desktop thumbnail previews)
VNC_SCREENSHOT_ENABLED=true
VNC_SCREENSHOT_QUALITY=75
VNC_SCREENSHOT_SCALE=0.5
VNC_SCREENSHOT_FORMAT=jpeg
VNC_SCREENSHOT_TIMEOUT=5.0

# Search engine configuration
# Options: duckduckgo, bing, google, baidu, whoogle, brave, tavily, serper
SEARCH_PROVIDER=duckduckgo

# Google search configuration, only used when SEARCH_PROVIDER=google
#GOOGLE_SEARCH_API_KEY=
#GOOGLE_SEARCH_ENGINE_ID=

# Whoogle configuration, only used when SEARCH_PROVIDER=whoogle
# Default points to the whoogle Docker service
WHOOGLE_URL=http://whoogle:5000

# Auth configuration
# Options: password, none, local
AUTH_PROVIDER=password

# Password auth configuration, only used when AUTH_PROVIDER=password
PASSWORD_SALT=
PASSWORD_HASH_ROUNDS=10

# Local auth configuration, only used when AUTH_PROVIDER=local
#LOCAL_AUTH_EMAIL=admin@example.com
#LOCAL_AUTH_PASSWORD=admin

# JWT configuration
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email configuration
# Only used when AUTH_PROVIDER=password
#EMAIL_HOST=smtp.gmail.com
#EMAIL_PORT=587
#EMAIL_USERNAME=your-email@gmail.com
#EMAIL_PASSWORD=your-password
#EMAIL_FROM=your-email@gmail.com

# MCP configuration
#MCP_CONFIG_PATH=/etc/mcp.json

# Log configuration
LOG_LEVEL=INFO

# Qdrant Vector Database
# High-performance vector database for semantic memory search
QDRANT_URL=http://qdrant:6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=true
QDRANT_COLLECTION=agent_memories
#QDRANT_API_KEY=

# =============================================================================
# Agent Enhancement Configuration (Phase 1-3)
# =============================================================================

# Multi-Agent Orchestration (Phase 2)
# Enable specialized agent dispatch for individual plan steps
# When true, steps are routed to specialized agents (researcher, coder, browser, etc.)
ENABLE_MULTI_AGENT=false

# Enable full swarm coordinator mode for complex tasks
# When true, uses CoordinatorFlow with parallel agent execution
ENABLE_COORDINATOR=false

# Enable LangGraph-based PlanActFlow
# Uses LangGraph StateGraph instead of custom workflow engine
# Provides built-in checkpointing, streaming, and better composability
USE_LANGGRAPH_FLOW=false

# Agent Enhancement Feature Flags
FEATURE_FAILURE_PREDICTION=false

# Maximum number of parallel agents in swarm mode
MULTI_AGENT_MAX_PARALLEL=3

# Browser Agent Configuration
BROWSER_AGENT_ENABLED=true
BROWSER_AGENT_MAX_STEPS=25
BROWSER_AGENT_TIMEOUT=300
BROWSER_AGENT_USE_VISION=true
BROWSER_AGENT_MAX_FAILURES=5

# =============================================================================
# Timeline Replay Configuration
# =============================================================================
# Enable recording of agent actions for timeline replay
ENABLE_TIMELINE_RECORDING=true

# Number of actions between automatic state snapshots
# Lower values = faster replay reconstruction, higher storage usage
TIMELINE_SNAPSHOT_INTERVAL=50

# Days to retain detailed timeline data before cleanup
TIMELINE_RETENTION_DAYS=30

# Maximum snapshots per session (prevents unbounded growth)
TIMELINE_MAX_SNAPSHOTS_PER_SESSION=1000

# Enable compression for snapshot data
TIMELINE_COMPRESS_SNAPSHOTS=true

# =============================================================================
# OpenReplay Session Recording Configuration
# =============================================================================
# Project key for OpenReplay tracker (must match projects table)
OPENREPLAY_PROJECT_KEY=pythinker-dev

# OpenReplay service URLs (for docker-compose-openreplay.yml)
OPENREPLAY_INGEST_URL=http://localhost:9001
OPENREPLAY_API_URL=http://localhost:8090
OPENREPLAY_ASSETS_URL=http://localhost:9002
OPENREPLAY_ASSIST_URL=ws://localhost:9003

# Canvas recording settings for sandbox view capture
OPENREPLAY_RECORD_CANVAS=true
OPENREPLAY_CANVAS_QUALITY=medium
OPENREPLAY_CANVAS_FPS=6

# Network capture settings
OPENREPLAY_CAPTURE_NETWORK=true
OPENREPLAY_OBSCURE_EMAILS=true

# Assist (co-browsing) settings
OPENREPLAY_ASSIST_ENABLED=true
OPENREPLAY_ASSIST_CALL_CONFIRM=true
OPENREPLAY_ASSIST_CONTROL_CONFIRM=true
