# =============================================================================
# Pythinker .gitignore
# =============================================================================

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ─── Virtual Environments ────────────────────────────────────────────────────
venv/
env/
ENV/
.venv
env.bak/
venv.bak/

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Testing & Coverage ─────────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.ruff_cache/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
docker-*.log

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn
.yarnrc
.pnp.*
.next/
out/
.nuxt/
.cache/
.parcel-cache/
.vercel/
.turbo/
storybook-static/
coverage/
.nyc_output/
.vite/

# ─── Docker & Local Databases ────────────────────────────────────────────────
db/
.chroma/

# ─── Build Artifacts ─────────────────────────────────────────────────────────
backend/results/*
!backend/results/.gitkeep

# ─── Sandbox Artifacts ───────────────────────────────────────────────────────
sandbox/*.md
!sandbox/README.md
# Duplicate apple_cursor checkout (canonical SVGs: frontend/src/assets/cursors/apple_cursor-main)
sandbox/apple_cursor/

# ─── Git Worktrees ───────────────────────────────────────────────────────────
.worktrees/

# ─── MCP Config (user-specific) ─────────────────────────────────────────────
mcp.json

# ─── Claude Code ────────────────────────────────────────────────────────────
Instructions.md
claude-code-backup/
@claude-code-backup/
# ─── Internal Dev Docs (local-only) ──────────────────────────────────────────
.tmp-*
*.mov
nanobot-main
openclaw-main
design*.html
Pythinker/
reference/


# Cron automation state
.pythinker-cron-state.json
.pythinker-cron.lock
