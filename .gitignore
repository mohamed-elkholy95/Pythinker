# =============================================================================
# Pythinker .gitignore
# =============================================================================

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ─── Virtual Environments ────────────────────────────────────────────────────
venv/
env/
ENV/
.venv
env.bak/
venv.bak/

# ─── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── IDE & Editor ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
*.code-workspace

# ─── AI Tool Configs (local-only) ───────────────────────────────────────────
CLAUDE.md
AGENTS.md
instructions.md
.opencode/
.cursor/
.claude/
.coderabbit.yaml
opencode.json
skills/
.github/agents/

# ─── Testing & Coverage ─────────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.ruff_cache/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
docker-*.log

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn
.yarnrc
.pnp.*
.next/
out/
.nuxt/
.cache/
.parcel-cache/
.vercel/
.turbo/
storybook-static/
coverage/
.nyc_output/
.vite/

# ─── Docker ──────────────────────────────────────────────────────────────────
docker-compose-test.yml

# ─── Build Artifacts ─────────────────────────────────────────────────────────
backend/results/*
!backend/results/.gitkeep

# ─── Sandbox Artifacts ───────────────────────────────────────────────────────
sandbox/*.md
!sandbox/README.md

# ─── Git Worktrees ───────────────────────────────────────────────────────────
.worktrees/

# ─── MCP Config (user-specific) ─────────────────────────────────────────────
mcp.json

# ─── Internal Dev Docs (local-only) ──────────────────────────────────────────
BROWSER_PERMISSION_DEBUG_GUIDE.md
COMPREHENSIVE_PYTHINKER_ARCHITECTURE_ENHANCEMENT_PLAN.md
DEEPCODE_INTEGRATION_COMPLETE.md
QUICK_START_2026.md
Playbook.md
report_12.md
docs/plans/
docs/plan/
docs/reports/
examples/

# ─── Dev Scripts (local-only) ────────────────────────────────────────────────
.dev.sh
build.sh
run.sh
test-like-github.sh
monitor_containers.sh
show_context_stats.py
test_openrouter.py
test_resource_blocking.py

# ─── Temp & Misc ─────────────────────────────────────────────────────────────
.tmp-*
*.mov
nanobot-main
openclaw-main
design*.html
Pythinker/
