# ==============================================================================
# PYTHINKER BACKEND CONFIGURATION
# ==============================================================================
# Copy this file to .env and update the values for your environment.
#
# IMPORTANT SECURITY NOTES:
# - Never commit .env files to version control
# - Generate secure random values for all secret keys
# - Use environment-specific values (dev vs production)
# ==============================================================================

# ------------------------------------------------------------------------------
# ENVIRONMENT
# ------------------------------------------------------------------------------
# Options: development, staging, production
# In production, stricter security validation is enforced
ENVIRONMENT=development
DEBUG=false

# ------------------------------------------------------------------------------
# LLM PROVIDER CONFIGURATION
# ------------------------------------------------------------------------------
# Provider: openai, ollama
# Note: Use 'openai' provider for OpenRouter (OpenAI-compatible API)
LLM_PROVIDER=openai

# OpenRouter API - Get your API key from https://openrouter.ai/keys
# OpenRouter provides access to 300+ models through OpenAI-compatible API
API_KEY=your-openrouter-api-key-here
API_BASE=https://openrouter.ai/api/v1

# NVIDIA Nemotron 3 Nano 30B A3B
# - 30B total params, ~3B active per forward pass (MoE architecture)
# - Context: 262k tokens on DeepInfra provider
# - Pricing: $0.06/M input tokens, $0.24/M output tokens
# - 4x higher throughput than Nemotron 2 Nano
# - Specialized for agentic AI systems with high compute efficiency
MODEL_NAME=nvidia/nemotron-3-nano-30b-a3b
# Optional: human-friendly name shown in the UI instead of the raw model ID
# MODEL_DISPLAY_NAME=Pythinker Pro
TEMPERATURE=0.3
MAX_TOKENS=8000

# Z.AI GLM-5 (OpenAI-compatible)
# API_KEY=your-zai-api-key-here
# MODEL_NAME=glm-5
# TEMPERATURE=0.3
# MAX_TOKENS=16384
# GLM_DISABLE_THINKING=true
# GLM-5 context window per docs.z.ai: 200K
# LLM_CONTEXT_WINDOW_OVERRIDE=200000
# General endpoint:
# API_BASE=https://api.z.ai/api/paas/v4
# Coding Plan endpoint (coding-only plan):
# API_BASE=https://api.z.ai/api/coding/paas/v4

# Alternative: Free tier (testing only - prompts/outputs logged, no production use)
# MODEL_NAME=nvidia/nemotron-3-nano-30b-a3b:free

# Optional: OpenRouter-specific headers for analytics
# OPENROUTER_HTTP_REFERER=https://your-site.com
# OPENROUTER_APP_TITLE=Pythinker

# Previous models (commented out)
# MODEL_NAME=openai/gpt-oss-120b  # GPT-OSS-120B (117B MoE)

# Ollama (if using local ollama provider)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------------------------
# ADAPTIVE MODEL SELECTION (MoE Cost Optimization)
# ------------------------------------------------------------------------------
# Enable to route tasks to cheaper/faster models based on complexity.
# All models must be accessible via the same API_BASE provider.
# ADAPTIVE_MODEL_SELECTION_ENABLED=true
#
# Fast tier — simple tasks, summaries, status checks ($0.04-$0.09/M input)
# FAST_MODEL=openai/gpt-oss-120b
# Alt: FAST_MODEL=xiaomi/mimo-v2-flash
#
# Balanced tier — standard execution (empty = uses MODEL_NAME)
# BALANCED_MODEL=deepseek/deepseek-chat
# Alt: BALANCED_MODEL=zhipu-ai/glm-4-air
#
# Powerful tier — complex reasoning, multi-step planning ($0.40-$0.60/M input)
# POWERFUL_MODEL=moonshotai/kimi-k2.5
# Alt: POWERFUL_MODEL=deepseek/deepseek-chat-v3-0324-speciale

# ------------------------------------------------------------------------------
# DEAL FINDER (Product price comparison & coupon search)
# ------------------------------------------------------------------------------
# Auto-enables when user intent is deal-related. Set to true to always enable.
# DEAL_SCRAPER_ENABLED=false
# DEAL_SCRAPER_MAX_STORES=10
# DEAL_SCRAPER_TIMEOUT=30
# DEAL_SCRAPER_COUPON_SOURCES=slickdeals,retailmenot,couponscom
# DEAL_SCRAPER_COMMUNITY_SEARCH=true
# DEAL_SCRAPER_OPEN_WEB_SEARCH=true

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# MongoDB
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=pythinker
# MONGODB_USERNAME=
# MONGODB_PASSWORD=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Qdrant (optional - for memory/embeddings)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agent_memories
# QDRANT_API_KEY=

# ------------------------------------------------------------------------------
# AUTHENTICATION & SECURITY (CRITICAL)
# ------------------------------------------------------------------------------
# Auth provider: password (database), local (single user), none (disabled)
AUTH_PROVIDER=password

# JWT Configuration
# REQUIRED IN PRODUCTION - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_TOKEN_BLACKLIST_ENABLED=true

# Password Hashing
# REQUIRED IN PRODUCTION - Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
PASSWORD_SALT=
PASSWORD_HASH_ROUNDS=600000
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# Local Auth (only if AUTH_PROVIDER=local)
# LOCAL_AUTH_EMAIL=admin@example.com
# LOCAL_AUTH_PASSWORD=your-secure-password-here

# Account Lockout Protection
ACCOUNT_LOCKOUT_ENABLED=true
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15
ACCOUNT_LOCKOUT_RESET_MINUTES=60

# Credential Encryption (for stored credentials)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CREDENTIAL_ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# CORS CONFIGURATION
# ------------------------------------------------------------------------------
# Comma-separated list of allowed origins
# REQUIRED IN PRODUCTION - e.g., https://app.example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://pythinker.pythought.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=10
RATE_LIMIT_BURST=10

# ------------------------------------------------------------------------------
# SANDBOX CONFIGURATION
# ------------------------------------------------------------------------------
# Static sandbox hostnames (comma-separated for dev multi-sandbox mode)
SANDBOX_ADDRESS=sandbox,sandbox2
SANDBOX_NETWORK=pythinker-network
SANDBOX_TTL_MINUTES=30
# SANDBOX_CHROME_ARGS=
# SANDBOX_HTTPS_PROXY=
# SANDBOX_HTTP_PROXY=

# ------------------------------------------------------------------------------
# SEARCH PROVIDER
# ------------------------------------------------------------------------------
# Provider: duckduckgo, bing, google, brave, tavily, serper, exa, jina
SEARCH_PROVIDER=duckduckgo
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
# BRAVE_SEARCH_API_KEY=
# TAVILY_API_KEY=           # Tavily AI Search (https://tavily.com)
# TAVILY_API_KEY_2=         # Fallback key (auto-rotates on quota/billing errors)
# TAVILY_API_KEY_3=         # Third fallback key
# TAVILY_API_KEY_4=         # Fourth fallback key
# TAVILY_API_KEY_5=         # Fifth fallback key
# TAVILY_API_KEY_6=         # Sixth fallback key
# TAVILY_API_KEY_7=         # Seventh fallback key
# TAVILY_API_KEY_8=         # Eighth fallback key
# TAVILY_API_KEY_9=         # Ninth fallback key
# SERPER_API_KEY=           # Serper.dev Google Search (free tier: 2500 queries/mo)
# SERPER_API_KEY_2=         # Fallback key (auto-rotates on quota/billing errors)
# SERPER_API_KEY_3=         # Third fallback key
# EXA_API_KEY=              # Exa semantic search (https://exa.ai)
# EXA_API_KEY_2=            # Fallback Exa key #2
# EXA_API_KEY_3=            # Fallback Exa key #3
# EXA_API_KEY_4=            # Fallback Exa key #4
# EXA_API_KEY_5=            # Fallback Exa key #5
# JINA_API_KEY=             # Jina Search/Reader API (https://jina.ai)
# JINA_API_KEY_2=           # Fallback Jina key #2
# JINA_API_KEY_3=           # Fallback Jina key #3
# JINA_API_KEY_4=           # Fallback Jina key #4
# JINA_API_KEY_5=           # Fallback Jina key #5
# SEARCH_USE_JINA_RERANK=false
# SEARCH_JINA_RERANK_TOP_N=8
# SEARCH_JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual

# ------------------------------------------------------------------------------
# SKILL ACTIVATION
# ------------------------------------------------------------------------------
# Default policy is explicit activation only (chat selection or /command)
SKILL_AUTO_TRIGGER_ENABLED=false

# ------------------------------------------------------------------------------
# CHANNEL GATEWAY (Telegram, Discord, Slack)
# ------------------------------------------------------------------------------
# Master toggle — all channel adapters are disabled until this is True.
# CHANNEL_GATEWAY_ENABLED=false
# CHANNEL_MESSAGE_BUS_SIZE=1000

# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=          # Comma-separated Telegram user IDs
# TELEGRAM_WEBHOOK_MODE=false
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_PROXY_URL=

# Discord
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=           # Comma-separated Discord user IDs
# DISCORD_GUILD_IDS=               # Comma-separated guild (server) IDs

# Slack
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_ALLOWED_USERS=             # Comma-separated Slack user IDs

# ------------------------------------------------------------------------------
# CRON SCHEDULING
# ------------------------------------------------------------------------------
# CRON_SERVICE_ENABLED=false
# CRON_MAX_JOBS_PER_USER=50
# CRON_DAILY_BUDGET_USD=1.0

# ------------------------------------------------------------------------------
# HEARTBEAT
# ------------------------------------------------------------------------------
# HEARTBEAT_ENABLED=false
# HEARTBEAT_INTERVAL_MINUTES=30

# ------------------------------------------------------------------------------
# SKILLS SYSTEM
# ------------------------------------------------------------------------------
# SKILLS_SYSTEM_ENABLED=false
# SKILLS_WORKSPACE_DIR=~/.pythinker/skills
# SKILLS_BUILTIN_ENABLED=true

# ------------------------------------------------------------------------------
# SUBAGENT SPAWNING
# ------------------------------------------------------------------------------
# SUBAGENT_SPAWNING_ENABLED=false
# SUBAGENT_MAX_CONCURRENT=3
# SUBAGENT_MAX_ITERATIONS=15

# ------------------------------------------------------------------------------
# BROWSER AGENT
# ------------------------------------------------------------------------------
BROWSER_AGENT_ENABLED=true
BROWSER_AGENT_MAX_STEPS=25
BROWSER_AGENT_TIMEOUT=300
BROWSER_AGENT_USE_VISION=true

# Anti-Bot / Stealth
BROWSER_STEALTH_ENABLED=true
BROWSER_STEALTH_MODE=basic
BROWSER_HUMAN_DELAYS=true
# BROWSER_PROXY_URL=

# Scrapling enhanced fetch workflow
SCRAPING_ENHANCED_FETCH=true
SCRAPING_ESCALATION_ENABLED=true
SCRAPING_STEALTH_ENABLED=true

# Stealth fetch configuration
STEALTH_CLOUDFLARE_ENABLED=true
STEALTH_CLOUDFLARE_TIMEOUT=60
STEALTH_CANVAS_NOISE=true
STEALTH_WEBGL_ENABLED=true
STEALTH_WEBRTC_BLOCK=true
STEALTH_GOOGLE_REFERER=true

# Stealth proxy rotation
STEALTH_PROXY_ENABLED=false
STEALTH_PROXY_LIST=
STEALTH_PROXY_HEALTH_CHECK_ENABLED=true
STEALTH_PROXY_HEALTH_CHECK_INTERVAL=300
STEALTH_PROXY_MAX_FAILURES=3

# Stealth session management
STEALTH_SESSION_MAX_PAGES=3
STEALTH_SESSION_TIMEOUT=30000
STEALTH_SESSION_NETWORK_IDLE=true
STEALTH_SESSION_IDLE_CLEANUP_ENABLED=true
STEALTH_SESSION_IDLE_CLEANUP_INTERVAL=60
STEALTH_SESSION_IDLE_THRESHOLD_SECONDS=300
STEALTH_DISABLE_RESOURCES=false

# Scraping cache and batching
SCRAPING_CACHE_ENABLED=true
SCRAPING_CACHE_L1_MAX_SIZE=100
SCRAPING_CACHE_L2_TTL=300
SCRAPING_CACHE_KEY_INCLUDE_MODE=true
SCRAPING_BATCH_MAX_CONCURRENCY=3

# ------------------------------------------------------------------------------
# OBSERVABILITY
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO

# OpenTelemetry (optional)
OTEL_ENABLED=false
# OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=pythinker-agent

# Alerting (optional)
# ALERT_WEBHOOK_URL=
# ALERT_WEBHOOK_TIMEOUT_SECONDS=3.0
# ALERT_THROTTLE_SECONDS=60

# ------------------------------------------------------------------------------
# SAFETY LIMITS
# ------------------------------------------------------------------------------
AUTONOMY_LEVEL=guided
MAX_ITERATIONS=200
MAX_TOOL_CALLS=300
MAX_EXECUTION_TIME_SECONDS=3600
# Idle watchdog: fires if no event is yielded for this many seconds.
# MUST exceed 2 × LLM_REQUEST_TIMEOUT + 61s so a slow provider can complete one
# full attempt + one retry before the watchdog kills the session.
# Auto-floored at runtime if set too low (see Settings.effective_workflow_idle_timeout).
# Default: 660s (= 2 × 300s + 60s margin). Raise if using a very slow LLM provider.
WORKFLOW_IDLE_TIMEOUT_SECONDS=660
MAX_TOKENS_PER_RUN=500000
# MAX_COST_USD=

# File System Permissions
ALLOW_FILE_SYSTEM_WRITE=true
ALLOW_FILE_SYSTEM_DELETE=false
ALLOW_SHELL_EXECUTE=true
ALLOW_BROWSER_NAVIGATION=true
ALLOW_PAYMENT_OPERATIONS=false

# ------------------------------------------------------------------------------
# LLM TIMEOUT & RELIABILITY
# ------------------------------------------------------------------------------
# Per-request timeout for tool-enabled LLM calls (seconds).
# GLM-5 p95 tool-call latency is ~75s; 90s lets most first attempts succeed.
# Backoff chain: 90s → 180s → 300s (capped). Set to 0 to disable.
LLM_TOOL_REQUEST_TIMEOUT=90.0

# Max retry attempts after tool-call timeout (2 retries = 3 total attempts).
LLM_TOOL_TIMEOUT_MAX_RETRIES=2

# Total timeout for a single LLM HTTP request (connect + read + write).
LLM_REQUEST_TIMEOUT=300.0

# Threshold (seconds) above which LLM calls are logged at WARNING level.
# Raise for slow providers to reduce log noise.
LLM_SLOW_REQUEST_THRESHOLD=45.0

# Middleware pipeline: compose retry/concurrency/metrics as chainable layers.
FEATURE_LLM_MIDDLEWARE_PIPELINE=true

# Retry budget: caps retries at 15/task, 30/min to prevent cascade amplification.
FEATURE_LLM_RETRY_BUDGET=true

# Health scoring: sliding-window latency + error rate (shadow mode: log only).
FEATURE_LLM_HEALTH_SCORING=true

# Provider fallback: try next provider on primary exhaustion (requires chain config).
FEATURE_LLM_PROVIDER_FALLBACK=false
# Comma-separated ordered list of provider names (e.g., "openai,anthropic,ollama").
# LLM_PROVIDER_FALLBACK_CHAIN=

# ------------------------------------------------------------------------------
# WORKSPACE AUTO-INITIALIZATION
# ------------------------------------------------------------------------------
# Automatically initialize workspace with Python venv on first message
WORKSPACE_AUTO_INIT=true
WORKSPACE_DEFAULT_TEMPLATE=python
WORKSPACE_DEFAULT_PROJECT_NAME=project

# ------------------------------------------------------------------------------
# MCP CONFIGURATION
# ------------------------------------------------------------------------------
MCP_CONFIG_PATH=/etc/mcp.json

# ------------------------------------------------------------------------------
# AGENT ENHANCEMENT FEATURE FLAGS (Phases 1-5)
# ------------------------------------------------------------------------------
# Phase 1: Python 3.11+ TaskGroup for safer async concurrency
FEATURE_TASKGROUP_ENABLED=true

# Phase 2: Enhanced streaming API for improved event handling
FEATURE_SSE_V2=true

# Phase 3: Pydantic structured LLM outputs with validation retry
FEATURE_STRUCTURED_OUTPUTS=true

# Phase 4: Parallel MongoDB/Qdrant memory writes
FEATURE_PARALLEL_MEMORY=true

# Adaptive Verbosity + Clarification
# When true: logs clarification signal but skips pause.
# When false: ambiguous prompts can pause for user clarification.
FEATURE_ADAPTIVE_VERBOSITY_SHADOW=false
