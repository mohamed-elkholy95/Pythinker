# ==============================================================================
# PYTHINKER BACKEND CONFIGURATION
# ==============================================================================
# Copy this file to .env and update the values for your environment.
#
# IMPORTANT SECURITY NOTES:
# - Never commit .env files to version control
# - Generate secure random values for all secret keys
# - Use environment-specific values (dev vs production)
# ==============================================================================

# ------------------------------------------------------------------------------
# ENVIRONMENT
# ------------------------------------------------------------------------------
# Options: development, staging, production
# In production, stricter security validation is enforced
ENVIRONMENT=development
DEBUG=false

# ------------------------------------------------------------------------------
# LLM PROVIDER CONFIGURATION
# ------------------------------------------------------------------------------
# Provider: openai, ollama
# Note: Use 'openai' provider for OpenRouter (OpenAI-compatible API)
LLM_PROVIDER=openai

# OpenRouter API - Get your API key from https://openrouter.ai/keys
# OpenRouter provides access to 300+ models through OpenAI-compatible API
API_KEY=your-openrouter-api-key-here
API_BASE=https://openrouter.ai/api/v1

# NVIDIA Nemotron 3 Nano 30B A3B
# - 30B total params, ~3B active per forward pass (MoE architecture)
# - Context: 262k tokens on DeepInfra provider
# - Pricing: $0.06/M input tokens, $0.24/M output tokens
# - 4x higher throughput than Nemotron 2 Nano
# - Specialized for agentic AI systems with high compute efficiency
MODEL_NAME=nvidia/nemotron-3-nano-30b-a3b
TEMPERATURE=0.3
MAX_TOKENS=8000

# Alternative: Free tier (testing only - prompts/outputs logged, no production use)
# MODEL_NAME=nvidia/nemotron-3-nano-30b-a3b:free

# Optional: OpenRouter-specific headers for analytics
# OPENROUTER_HTTP_REFERER=https://your-site.com
# OPENROUTER_APP_TITLE=Pythinker

# Previous models (commented out)
# MODEL_NAME=openai/gpt-oss-120b  # GPT-OSS-120B (117B MoE)

# Ollama (if using local ollama provider)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
# MongoDB
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=pythinker
# MONGODB_USERNAME=
# MONGODB_PASSWORD=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Qdrant (optional - for memory/embeddings)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agent_memories
# QDRANT_API_KEY=

# ------------------------------------------------------------------------------
# AUTHENTICATION & SECURITY (CRITICAL)
# ------------------------------------------------------------------------------
# Auth provider: password (database), local (single user), none (disabled)
AUTH_PROVIDER=password

# JWT Configuration
# REQUIRED IN PRODUCTION - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_TOKEN_BLACKLIST_ENABLED=true

# Password Hashing
# REQUIRED IN PRODUCTION - Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
PASSWORD_SALT=
PASSWORD_HASH_ROUNDS=600000
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=false

# Local Auth (only if AUTH_PROVIDER=local)
# LOCAL_AUTH_EMAIL=admin@example.com
# LOCAL_AUTH_PASSWORD=your-secure-password-here

# Account Lockout Protection
ACCOUNT_LOCKOUT_ENABLED=true
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=15
ACCOUNT_LOCKOUT_RESET_MINUTES=60

# Credential Encryption (for stored credentials)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CREDENTIAL_ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# CORS CONFIGURATION
# ------------------------------------------------------------------------------
# Comma-separated list of allowed origins
# REQUIRED IN PRODUCTION - e.g., https://app.example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=10
RATE_LIMIT_BURST=10

# ------------------------------------------------------------------------------
# SANDBOX CONFIGURATION
# ------------------------------------------------------------------------------
SANDBOX_ADDRESS=http://sandbox:8080
SANDBOX_NETWORK=pythinker-network
SANDBOX_TTL_MINUTES=30
# SANDBOX_CHROME_ARGS=
# SANDBOX_HTTPS_PROXY=
# SANDBOX_HTTP_PROXY=

# ------------------------------------------------------------------------------
# SEARCH PROVIDER
# ------------------------------------------------------------------------------
# Provider: duckduckgo, bing, google, brave, tavily, serper
SEARCH_PROVIDER=duckduckgo
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=
# BRAVE_SEARCH_API_KEY=
# TAVILY_API_KEY=           # Tavily AI Search (https://tavily.com)
# TAVILY_API_KEY_2=         # Fallback key (auto-rotates on quota/billing errors)
# TAVILY_API_KEY_3=         # Third fallback key
# TAVILY_API_KEY_4=         # Fourth fallback key
# TAVILY_API_KEY_5=         # Fifth fallback key
# TAVILY_API_KEY_6=         # Sixth fallback key
# TAVILY_API_KEY_7=         # Seventh fallback key
# TAVILY_API_KEY_8=         # Eighth fallback key
# TAVILY_API_KEY_9=         # Ninth fallback key
# SERPER_API_KEY=           # Serper.dev Google Search (free tier: 2500 queries/mo)
# SERPER_API_KEY_2=         # Fallback key (auto-rotates on quota/billing errors)
# SERPER_API_KEY_3=         # Third fallback key

# ------------------------------------------------------------------------------
# BROWSER AGENT
# ------------------------------------------------------------------------------
BROWSER_AGENT_ENABLED=true
BROWSER_AGENT_MAX_STEPS=25
BROWSER_AGENT_TIMEOUT=300
BROWSER_AGENT_USE_VISION=true

# Anti-Bot / Stealth
BROWSER_STEALTH_ENABLED=true
BROWSER_STEALTH_MODE=basic
BROWSER_HUMAN_DELAYS=true
# BROWSER_PROXY_URL=

# ------------------------------------------------------------------------------
# OBSERVABILITY
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO

# OpenTelemetry (optional)
OTEL_ENABLED=false
# OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=pythinker-agent

# Alerting (optional)
# ALERT_WEBHOOK_URL=
# ALERT_WEBHOOK_TIMEOUT_SECONDS=3.0
# ALERT_THROTTLE_SECONDS=60

# ------------------------------------------------------------------------------
# SAFETY LIMITS
# ------------------------------------------------------------------------------
AUTONOMY_LEVEL=guided
MAX_ITERATIONS=200
MAX_TOOL_CALLS=300
MAX_EXECUTION_TIME_SECONDS=3600
MAX_TOKENS_PER_RUN=500000
# MAX_COST_USD=

# File System Permissions
ALLOW_FILE_SYSTEM_WRITE=true
ALLOW_FILE_SYSTEM_DELETE=false
ALLOW_SHELL_EXECUTE=true
ALLOW_BROWSER_NAVIGATION=true
ALLOW_PAYMENT_OPERATIONS=false

# ------------------------------------------------------------------------------
# WORKSPACE AUTO-INITIALIZATION
# ------------------------------------------------------------------------------
# Automatically initialize workspace with Python venv on first message
WORKSPACE_AUTO_INIT=true
WORKSPACE_DEFAULT_TEMPLATE=python
WORKSPACE_DEFAULT_PROJECT_NAME=project

# ------------------------------------------------------------------------------
# MCP CONFIGURATION
# ------------------------------------------------------------------------------
MCP_CONFIG_PATH=/etc/mcp.json

# ------------------------------------------------------------------------------
# AGENT ENHANCEMENT FEATURE FLAGS (Phases 1-5)
# ------------------------------------------------------------------------------
# Phase 1: Python 3.11+ TaskGroup for safer async concurrency
FEATURE_TASKGROUP_ENABLED=true

# Phase 2: Browser-use as first-class LangGraph node (requires browser_use package)
FEATURE_BROWSER_NODE=true

# Phase 3: LangGraph astream_events v2 API for improved streaming
FEATURE_SSE_V2=true

# Phase 4: Pydantic structured LLM outputs with validation retry
FEATURE_STRUCTURED_OUTPUTS=true

# Phase 5: Parallel MongoDB/Qdrant memory writes
FEATURE_PARALLEL_MEMORY=true
