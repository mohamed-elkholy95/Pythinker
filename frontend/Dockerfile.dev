# Development Dockerfile using Node.js for better Vite compatibility
# Note: Bun has issues with Vite's WebSocket proxy (socket.destroySoon not implemented)
FROM node:22-slim

# Install bun for package management (faster installs)
RUN npm install -g bun

# Set working directory
WORKDIR /app

# Copy package files first for better caching
COPY package.json bun.lock* ./

# Install dependencies using bun (faster) but run with node (compatible)
RUN bun install

# The source code will be mounted as a volume
# node_modules from the image will be used

# Expose Vite dev server port
EXPOSE 5173

# Start development server with Node.js for full API compatibility
CMD ["npx", "vite", "--host", "0.0.0.0"]
