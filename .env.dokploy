# ------------------------------------------------------------------------------
# CORS CONFIGURATION (Updated with your actual IPs)
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://72.60.164.225:5174,http://100.105.81.30:5174
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

# ------------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# ------------------------------------------------------------------------------
# AUTH_PROVIDER options:
#   - "local": Single admin account (hardcoded credentials below)
#   - "password": Database-backed multi-user auth
#   - "none": No authentication (⚠️ insecure for production)
AUTH_PROVIDER=local
LOCAL_AUTH_EMAIL=admin@pythinker.com
LOCAL_AUTH_PASSWORD=SecureVPS2026!Admin

# JWT Configuration (Your actual secret)
JWT_SECRET_KEY=o5pYti2Opd_GZ6cU-va4HH_HVILF32o48N73_LxUlZqmXmhjCxHxxTvxIqqwwpvG
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# BROWSER AGENT
# ------------------------------------------------------------------------------
BROWSER_AGENT_ENABLED=true
BROWSER_AGENT_MAX_STEPS=25
BROWSER_AGENT_TIMEOUT=300
BROWSER_AGENT_USE_VISION=true
BROWSER_AGENT_MAX_FAILURES=5

# ------------------------------------------------------------------------------
# AGENT ENHANCEMENT FEATURES
# ------------------------------------------------------------------------------
ENABLE_MULTI_AGENT=false
ENABLE_COORDINATOR=false
FEATURE_FAILURE_PREDICTION=true
MULTI_AGENT_MAX_PARALLEL=3

# Feature Flags (Phases 1-5)
FEATURE_TASKGROUP_ENABLED=true
FEATURE_SSE_V2=true
FEATURE_STRUCTURED_OUTPUTS=true
FEATURE_PARALLEL_MEMORY=true

# ------------------------------------------------------------------------------
# TIMELINE REPLAY
# ------------------------------------------------------------------------------
ENABLE_TIMELINE_RECORDING=true
TIMELINE_SNAPSHOT_INTERVAL=50
TIMELINE_RETENTION_DAYS=30
TIMELINE_MAX_SNAPSHOTS_PER_SESSION=1000
TIMELINE_COMPRESS_SNAPSHOTS=true

# ------------------------------------------------------------------------------
# MONITORING (Grafana + Prometheus)
# ------------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=Debug-09912

# ------------------------------------------------------------------------------
# LOGGING & OBSERVABILITY
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# ENVIRONMENT
# ------------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=10
RATE_LIMIT_BURST=10

# ------------------------------------------------------------------------------
# SAFETY LIMITS
# ------------------------------------------------------------------------------
AUTONOMY_LEVEL=guided
MAX_ITERATIONS=200
MAX_TOOL_CALLS=300
MAX_EXECUTION_TIME_SECONDS=3600
MAX_TOKENS_PER_RUN=500000
ALLOW_FILE_SYSTEM_WRITE=true
ALLOW_FILE_SYSTEM_DELETE=false
ALLOW_SHELL_EXECUTE=true
ALLOW_BROWSER_NAVIGATION=true
ALLOW_PAYMENT_OPERATIONS=false

# ------------------------------------------------------------------------------
# WORKSPACE AUTO-INITIALIZATION
# ------------------------------------------------------------------------------
WORKSPACE_AUTO_INIT=true
WORKSPACE_DEFAULT_TEMPLATE=python
WORKSPACE_DEFAULT_PROJECT_NAME=project

# ------------------------------------------------------------------------------
# GITHUB TOKENS (Optional - for GitHub integration)
# ------------------------------------------------------------------------------
GH_TOKEN=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
GITHUB_TOKEN=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

# ------------------------------------------------------------------------------
# SUPPRESS WARNINGS
# ------------------------------------------------------------------------------
GRPC_ENABLE_FORK_SUPPORT=0
NODE_OPTIONS=--no-deprecation
