# ==============================================================================
# PYTHINKER DOKPLOY DEPLOYMENT CONFIGURATION
# ==============================================================================
# This is an exact replica of your local .env for Dokploy deployment
# Paste ALL of this into Dokploy's Environment tab
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM CONFIGURATION (Kimi Code API - Tested & Working)
# ------------------------------------------------------------------------------
LLM_PROVIDER=openai
API_KEY=sk-kimi-0QnR9NRIkLcXZf0txuvVBtlNf7FaywwUlvy0aapclD3I6dBbvPfYIm4ETdlkPaHA
API_BASE=https://api.kimi.com/coding/v1
MODEL_NAME=kimi-for-coding
TEMPERATURE=0.6
MAX_TOKENS=16384

# ------------------------------------------------------------------------------
# EMBEDDING CONFIGURATION (OpenAI)
# ------------------------------------------------------------------------------
EMBEDDING_API_KEY=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
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION (Docker Compose defaults)
# ------------------------------------------------------------------------------
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=pythinker
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ------------------------------------------------------------------------------
# QDRANT VECTOR DATABASE
# ------------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=true
QDRANT_COLLECTION=agent_memories
QDRANT_USER_KNOWLEDGE_COLLECTION=user_knowledge
QDRANT_TASK_ARTIFACTS_COLLECTION=task_artifacts
QDRANT_TOOL_LOGS_COLLECTION=tool_logs

# ------------------------------------------------------------------------------
# MINIO S3 STORAGE
# MINIO_ROOT_USER/MINIO_ROOT_PASSWORD = MinIO server credentials (docker-compose)
# MINIO_ACCESS_KEY/MINIO_SECRET_KEY = Backend client credentials (must match)
# ------------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=pythinker
MINIO_USE_SSL=false
FILE_STORAGE_BACKEND=minio

# ------------------------------------------------------------------------------
# SANDBOX CONFIGURATION
# ------------------------------------------------------------------------------
SANDBOX_LIFECYCLE_MODE=static
SANDBOX_ADDRESS=sandbox
SANDBOX_IMAGE=pythinker/pythinker-sandbox
SANDBOX_NAME_PREFIX=sandbox
SANDBOX_TTL_MINUTES=30
SANDBOX_NETWORK=pythinker-network
SANDBOX_SHM_SIZE=1g
SANDBOX_MEM_LIMIT=3g
SANDBOX_CPU_LIMIT=1.5
SANDBOX_PIDS_LIMIT=300

# Sandbox Pool (2 concurrent tasks)
SANDBOX_POOL_ENABLED=true
SANDBOX_POOL_MIN_SIZE=1
SANDBOX_POOL_MAX_SIZE=2
SANDBOX_POOL_WARMUP_INTERVAL=30
SANDBOX_POOL_IDLE_TTL_SECONDS=300
SANDBOX_POOL_PAUSE_IDLE=true
SANDBOX_POOL_HOST_MEMORY_THRESHOLD=0.80
SANDBOX_POOL_REAPER_INTERVAL=60
SANDBOX_POOL_REAPER_GRACE_PERIOD=120

# ------------------------------------------------------------------------------
# SEARCH PROVIDER (Serper + Tavily with rotation)
# ------------------------------------------------------------------------------
SEARCH_PROVIDER=serper
SEARCH_PREFER_BROWSER=false

# Serper.dev keys (auto-rotates)
SERPER_API_KEY=80af55eb50b671bcc0305cb96c76489206a68898
